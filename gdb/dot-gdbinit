# set dis intel
set disassembly intel
# http://www.dirac.org/linux/gdb/03-Initialization,_Listing,_And_Running.php
set prompt \001\033[32m\002(gdb)\001\033[0m\002\040

# The Go team used the python scripting capabilities of gdb to allow for
# go runtime support.  I fucking hate python but let's allow it.
add-auto-load-safe-path /usr/local/go/src/runtime/runtime-gdb.py

